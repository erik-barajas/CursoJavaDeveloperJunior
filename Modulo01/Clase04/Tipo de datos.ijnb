    {
      "id": "3cafca54-d500-4d28-ba8a-232005b97bab",
      "cell_type": "code",
      "source": "//Uso de paréntesis para controlar el orden de las operaciones.\r\nint resultado = (2 + 3) * 4; // Sin paréntesis, el resultado sería 14, con paréntesis es 20\r\nSystem.out.println(\"El resultado de (2 + 3) * 4 es: \" + resultado);",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 24,
          "success": true
        }
      },
      "execution_count": 24,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "El resultado de (2 + 3) * 4 es: 20\r\n"
          },
          "metadata": {},
          "execution_count": 24
        }
      ]
    },
    {
      "id": "5478d2f5-4130-438d-9d2a-1a543267ba37",
      "cell_type": "code",
      "source": "/* Operadores ternarios, se utilizan para asignar un valor a una variable dependiendo de una condición.\r\n  Su estructura es: condición ? valor_si_verdadero : valor_si_falso */\r\nint a = 10;\r\nString resultado = (a < 2) ? \"El número es menor que 2\" : \"El número es mayor o igual a 2\";  \r\nSystem.out.println(\"El número \" + a + \" es: \" + resultado); // \"El número 10 es: El número es mayor o igual a 2\"",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 27,
          "success": true
        }
      },
      "execution_count": 27,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "El número 10 es: El número es mayor o igual a 2\r\n"
          },
          "metadata": {},
          "execution_count": 27
        }
      ]
    },
