      "id": "6934d12d-c838-4b05-8529-9b11a1037d70",
      "cell_type": "code",
      "source": "byte miByte = 127; // Rango: -128 a 127\r\nshort miShort = 32767; // Rango: -32,768 a 32,767\r\nint miInt = 2147483647; // Rango: -2,147,483,648 a 2,147,483,647\r\nlong miLong = 9223372036854775807L; // Rango: -9,223,372,036,854,775,808 a 9,223,372,036,854,775,807\r\nfloat miFloat = 3.14f; // Precisión de 7 dígitos\r\ndouble miDouble = 3.141592653589793; // Precisión de 15 dígitos\r\nchar miChar = 'A'; // Caracter único un error común es colocar el tipo de dato char entre comillas dobles, lo correcto es entre comillas simples\r\nboolean miBoolean = true; // Verdadero o falso\r\nString miString = \"Hola, mundo!\"; // Cadena de texto",
      "metadata": {
        "language": "java"
      },
      "execution_count": null,
      "outputs": []
